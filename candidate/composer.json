{
  "name": "geektastic/phpmpwgg",
  "description": "A game where multiple players submit words and get points for scoring the correct letters or words",
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "": ""
    },
    "files": [
      "MultiplayerGuessingGame.php",
      "VocabularyCheckerImpl.php",
      "WordGuessingGame.php",
      "GuessValidator.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "test/"
    }
  }
}
